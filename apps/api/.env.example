API_PORT=4000
NODE_ENV=development

GEMINI_API_KEY=
# Optional override. Free-tier daily quotas (as of 2026):
#   gemini-2.5-flash       — 20 RPD     (tightest)
#   gemini-2.5-flash-lite  — 1,000 RPD  (recommended for dev)
#   gemini-2.0-flash       — 1,500 RPD
GEMINI_MODEL=gemini-2.5-flash-lite

FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

WEB_ORIGIN=http://localhost:3000

# Google Calendar OAuth (https://console.cloud.google.com/apis/credentials)
# Create an OAuth 2.0 Client ID of type "Web application".
# Authorized redirect URI MUST be: http://localhost:4000/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4000/auth/google/callback

# IANA timezone used when adding events to user calendars (e.g. Asia/Jakarta, Europe/London)
DEFAULT_TZ=Asia/Jakarta

# ElevenLabs natural TTS for Speaking module (optional but recommended)
# Sign up: https://elevenlabs.io  → Profile → API Keys
# Free tier: 10,000 chars/month — server caches by (text, voice) so re-plays are free.
# If unset, /speak falls back to browser Web Speech (more robotic).
ELEVENLABS_API_KEY=

# Conversational AI agent (realtime mock interview). One-time setup:
# 1. https://elevenlabs.io/app/conversational-ai → "+ Create Agent"
# 2. System prompt + dynamic vars: see README "Speaking realtime setup"
# 3. Copy Agent ID into this env var.
ELEVENLABS_AGENT_ID=
