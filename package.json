{
  "name": "ielts-platform",
  "private": true,
  "version": "0.1.0",
  "description": "All-in-one IELTS learning platform — accelerate to higher band",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:web": "pnpm --filter web dev",
